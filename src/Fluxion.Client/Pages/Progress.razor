@page "/progress"
@using Fluxion.Core.Models
@inject HttpClient Http
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject IJSRuntime JS
@inject NavigationManager Navigation

<PageTitle>Knowledge Graph — Fluxion</PageTitle>

<div class="center-panel">
    <div class="page-header" style="border-bottom:none;">
        <div>
            <h1 class="heading-xl text-gradient">Knowledge Graph</h1>
            <p class="text-dim mt-sm">Your personalized path through the curriculum topology</p>
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="text-center" style="padding:4rem 0;">
            <div class="spinner mb-lg" style="margin:0 auto"></div>
            <p class="text-dim">Rendering curriculum topology…</p>
        </div>
    }
    else if (!string.IsNullOrEmpty(_error))
    {
        <div class="glass-card" style="padding:2rem; text-align:center;">
            <div style="font-size:2rem; margin-bottom:1rem;">⚠️</div>
            <p class="text-dim mb-lg">@_error</p>
            <button class="btn btn-cyan" @onclick="OnInitializedAsync">Retry Sync →</button>
        </div>
    }
    else if (_nodes == null || !_nodes.Any())
    {
        <div class="glass-card" style="padding:2rem; text-align:center;">
            <p class="text-dim">No curriculum nodes found.</p>
        </div>
    }
    else
    {
        <div class="graph-container">
            <canvas id="knowledge-graph-canvas" style="width:100%; height:100%; display:block; cursor:crosshair; opacity:0; transition: opacity 300ms;"></canvas>
            
            <div class="graph-legend">
                <div class="legend-item">
                    <span class="legend-dot" style="background: #10B981; box-shadow: 0 0 10px #10B981;"></span>
                    <span>Mastered</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background: #7C3AED; box-shadow: 0 0 10px #7C3AED;"></span>
                    <span>In Progress</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background: #94A3B8;"></span>
                    <span>Available</span>
                </div>
                <div class="legend-item">
                    <span class="legend-dot" style="background: #334155;"></span>
                    <span>Locked</span>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<KnowledgeNode>? _nodes;
    private Dictionary<string, double> _mastery = new();
    private string? _error;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _isLoading = true;
            _error = null;
            
            var token = await LocalStorage.GetItemAsync<string>("authToken");
            
            if (!string.IsNullOrWhiteSpace(token))
            {
                Http.DefaultRequestHeaders.Authorization =
                    new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            else
            {
                _error = "Neural identity not found. Please re-authenticate.";
                _isLoading = false;
                return;
            }

            // Load data
            _nodes = await Http.GetFromJsonAsync<List<KnowledgeNode>>("api/curriculum/graph/nodes");

            var learnerId = await LocalStorage.GetItemAsync<Guid>("learnerId");
            if (learnerId != Guid.Empty)
            {
                try
                {
                    var learner = await Http.GetFromJsonAsync<LearnerProfile>($"api/curriculum/learners/{learnerId}");
                    if (learner?.MasteryEntries != null)
                    {
                        _mastery = learner.MasteryEntries.ToDictionary(m => m.NodeId.ToString(), m => m.MasteryScore);
                    }
                }
                catch { /* Optional: log or handle partial failure */ }
            }
        }
        catch (HttpRequestException ex)
        {
            if (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await LocalStorage.RemoveItemAsync("authToken");
                await LocalStorage.RemoveItemAsync("learnerId");
                Navigation.NavigateTo("/login");
                return;
            }
            _error = $"Topology sync error: {ex.Message}";
        }
        catch (Exception ex)
        {
            _error = $"Neural link calibration failed: {ex.Message}";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (_nodes != null && _nodes.Any() && !_isLoading)
            {
                await Task.Delay(100); 
                await JS.InvokeVoidAsync("fluxionGraph.draw", _nodes, _mastery, "knowledge-graph-canvas");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Graph Render Error: {ex.Message}");
        }
    }
}
