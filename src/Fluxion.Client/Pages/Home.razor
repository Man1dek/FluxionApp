@page "/"
@using Fluxion.Core.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@implements IAsyncDisposable

<PageTitle>Fluxion — AI-Powered Learning</PageTitle>

@if (_hasError)
{
    <!-- Unauthenticated / Error State — Premium Landing Page -->
    <section class="hero-section">
        <h1 class="hero-title">
            The future of <span class="accent-word">adaptive</span> learning
        </h1>
        <p class="hero-subtitle">
            An AI-powered engine that morphs content in real-time based on your 
            cognitive profile. Personalized curriculum, reimagined.
        </p>
        <div class="hero-actions">
            <a href="/login" class="btn btn-primary" style="text-decoration:none;">Sign In →</a>
            <a href="/register" class="btn btn-outline" style="text-decoration:none;">Create Account</a>
        </div>
    </section>

    <div class="bento-grid" style="max-width:920px; margin:0 auto; padding:0 2.5rem;">
        <div class="bento-card">
            <div class="bento-icon">🧠</div>
            <h4>Adaptive Content</h4>
            <p>AI analyzes your cognitive load in real-time to morph lessons to your exact level and learning style.</p>
        </div>
        <div class="bento-card">
            <div class="bento-icon">📊</div>
            <h4>Mastery Tracking</h4>
            <p>Progress through a knowledge graph — unlock new concepts as you master fundamentals.</p>
        </div>
        <div class="bento-card">
            <div class="bento-icon">⚡</div>
            <h4>Active Recall</h4>
            <p>Practice exercises evaluated by AI with instant feedback and precision mastery scoring.</p>
        </div>
    </div>

    <div class="proof-section" style="max-width:920px; margin:0 auto;">
        <div class="section-label">Built with purpose</div>
        <div class="proof-quote">
            "Learning should feel like a conversation, not a lecture.
            Fluxion makes that possible."
        </div>
        <div class="proof-attribution">The Fluxion Team</div>
    </div>

    <div class="cta-section">
        <h2>Ready to transform how you learn?</h2>
        <p>Start your AI-orchestrated journey today. No credit card required.</p>
        <div class="hero-actions">
            <a href="/register" class="btn btn-primary" style="text-decoration:none;">Get Started →</a>
        </div>
    </div>
}
else
{
    <div class="page-header">
        <div>
            <h1 class="heading-xl text-shimmer">Kinetic Curriculum</h1>
            <p class="text-dim mt-sm">AI-orchestrated adaptive learning environment</p>
        </div>
        <div class="flex gap-md items-center">
            @if (_learner != null)
            {
                <div class="stat-badge">
                   <span>🧠</span> @(_learner.CognitiveLoadIndex.ToString("P0")) Load
                </div>
                <div class="stat-badge">
                   <span>🎯</span> @(_learner.MasteryEntries.Count(m => m.MasteryScore >= 0.7)) / @_totalNodes Mastered
                </div>
            }
        </div>
    </div>

    @if (_isLoading)
    {
        <div class="glass-card module-card text-center" style="padding:4rem 2rem;">
            <div class="spinner mb-lg"></div>
            <h2 class="heading-md text-gradient mb-sm">Orchestrating Next Module…</h2>
            <p class="text-dim">Analyzing your cognitive profile and preparing content.</p>
            <div class="flex gap-sm items-center mt-xl" style="justify-content:center;">
                <div class="skeleton" style="width:200px; height:14px;"></div>
                <div class="skeleton" style="width:160px; height:14px;"></div>
                <div class="skeleton" style="width:120px; height:14px;"></div>
            </div>
        </div>
    }
    else if (_currentModule != null)
    {
        <div class="glass-card module-card">
            <div class="module-meta">
                <span class="tag tag-pink">@_currentModule.SelectedFormat</span>
                <div class="difficulty-indicator">
                    @for (int i = 1; i <= 10; i++)
                    {
                        <span class="diff-dot @(i <= _currentModule.AdjustedDifficulty ? "active" : "")"></span>
                    }
                </div>
                <span class="tag tag-accent">Level @_currentModule.AdjustedDifficulty</span>
            </div>
            
            <h2 class="heading-lg text-gradient mb-lg">@_currentModule.NodeTitle</h2>

            @if (!string.IsNullOrEmpty(_currentModule.MorphingRationale))
            {
                <div class="ai-rationale">
                    <div class="label">AI Morphing Logic</div>
                    <p class="text-dim" style="margin:0; font-size:0.88rem;">@_currentModule.MorphingRationale</p>
                </div>
            }

            <div class="md-content mb-xl">
                @((MarkupString)Markdig.Markdown.ToHtml(_currentModule.Content))
            </div>

            <div class="practice-section">
                <h3 class="heading-md mb-lg flex items-center gap-sm">
                    <span>✍️</span> Active Recall
                </h3>
                
                @if (_currentModule.PracticeQuestions.Any())
                {
                    <div class="mb-lg">
                        @foreach (var q in _currentModule.PracticeQuestions)
                        {
                            <div class="question-item">@q</div>
                        }
                    </div>
                }

                <div class="mb-lg">
                    <textarea @bind="_studentResponse" 
                              placeholder="Describe your understanding or provide the solution…" 
                              class="input"></textarea>
                </div>

                <div class="text-right">
                    <button class="btn btn-primary" 
                            @onclick="SubmitResponse" 
                            disabled="@(_isSubmitting || string.IsNullOrWhiteSpace(_studentResponse))">
                        @(_isSubmitting ? "Evaluating…" : "Submit to AI Engine →")
                    </button>
                </div>
            </div>

            @if (_feedback != null)
            {
                <div class="feedback-card @(_feedback.NodeMastered ? "success" : "warning")">
                    <div class="score-ring">
                        @((_feedback.MasteryScore * 100).ToString("F0"))%
                    </div>
                    <div style="flex:1;">
                        <h4 class="heading-md mb-sm">@(_feedback.NodeMastered ? "Mastery Achieved!" : "Keep Going")</h4>
                        <p class="text-dim mb-md" style="font-size:0.9rem;">@_feedback.EvaluationDetails</p>
                        @if (_feedback.NodeMastered)
                        {
                            <button class="btn btn-success" @onclick="LoadNextModule">Next Module →</button>
                        }
                        else
                        {
                            <button class="btn btn-outline" @onclick="ClearFeedback">Try Again</button>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

@code {
    private Guid _learnerId;
    private LearnerProfile? _learner;
    private MorphedModule? _currentModule;
    private HubConnection? _hubConnection;
    private int _totalNodes = 15;

    private bool _isLoading = true;
    private bool _isSubmitting = false;
    private bool _hasError = false;
    private string _studentResponse = "";
    private DateTime _sessionStartTime;
    
    private Fluxion.Core.Models.StudentFeedback? _feedback;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _learnerId = Guid.NewGuid();
            
            var newLearnerReq = new { DisplayName = "Pioneer", PreferredFormat = ContentFormat.Interactive };
            var created = await Http.PostAsJsonAsync("api/curriculum/learners", newLearnerReq);

            if (!created.IsSuccessStatusCode)
            {
                _hasError = true;
                _isLoading = false;
                return;
            }

            _learner = await created.Content.ReadFromJsonAsync<LearnerProfile>();
            _learnerId = _learner!.Id;

            var apiUrl = Configuration.GetValue<string>("ApiBaseUrl") ?? "http://localhost:5215";
            _hubConnection = new HubConnectionBuilder()
                .WithUrl($"{apiUrl.TrimEnd('/')}/hubs/curriculum")
                .WithAutomaticReconnect()
                .Build();

            _hubConnection.On<MorphedModule>("ModuleMorphed", async (module) =>
            {
                _currentModule = module;
                _sessionStartTime = DateTime.UtcNow;
                _isLoading = false;
                await InvokeAsync(StateHasChanged);
            });

            _hubConnection.On<Fluxion.Core.Models.StudentFeedback>("MasteryUpdated", async (feedback) =>
            {
                _learner = await Http.GetFromJsonAsync<LearnerProfile>($"api/curriculum/learners/{_learnerId}");
                await InvokeAsync(StateHasChanged);
            });

            await _hubConnection.StartAsync();
            await _hubConnection.SendAsync("JoinLearnerGroup", _learnerId.ToString());

            await LoadNextModule();
        }
        catch
        {
            _hasError = true;
            _isLoading = false;
        }
    }

    private async Task LoadNextModule()
    {
        try
        {
            _isLoading = true;
            _feedback = null;
            _studentResponse = "";
            StateHasChanged();

            var module = await Http.GetFromJsonAsync<MorphedModule>($"api/curriculum/next/{_learnerId}");
            if (module == null)
            {
                _hasError = true;
            }
            else
            {
                _currentModule = module;
            }
            _sessionStartTime = DateTime.UtcNow;
            _isLoading = false;
        }
        catch
        {
            _hasError = true;
            _isLoading = false;
        }
    }

    private async Task SubmitResponse()
    {
        if (string.IsNullOrWhiteSpace(_studentResponse)) return;
        
        _isSubmitting = true;
        
        var timeSpent = (int)(DateTime.UtcNow - _sessionStartTime).TotalSeconds;
        var request = new 
        {
            LearnerId = _learnerId,
            NodeId = _currentModule!.NodeId,
            Response = _studentResponse,
            TimeSpentSeconds = timeSpent,
            HintRequests = 0,
            ErrorCount = 0
        };

        var response = await Http.PostAsJsonAsync("api/curriculum/submit", request);
        
        var jsonStr = await response.Content.ReadAsStringAsync();
        
        var doc = System.Text.Json.JsonDocument.Parse(jsonStr);
        _feedback = new Fluxion.Core.Models.StudentFeedback
        {
            MasteryScore = doc.RootElement.GetProperty("masteryScore").GetDouble(),
            EvaluationDetails = doc.RootElement.GetProperty("evaluationDetails").GetString() ?? "",
            NodeMastered = doc.RootElement.GetProperty("nodeMastered").GetBoolean(),
            NodeTitle = doc.RootElement.GetProperty("nodeTitle").GetString() ?? ""
        };

        _isSubmitting = false;
    }

    private void ClearFeedback()
    {
        _feedback = null;
    }

    public async ValueTask DisposeAsync()
    {
        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
