    private string CleanQuestion(string q) => System.Text.RegularExpressions.Regex.Replace(q.Trim(), @"^\d+\.\s+", "");

    enum QuestionType { Text, TrueFalse, Code }
    private QuestionType DetectQuestionType(string q)
    {
        var lower = q.ToLower();
        if (lower.Contains("true or false") || lower.Contains("true/false")) return QuestionType.TrueFalse;
        if ((lower.Contains("write") || lower.Contains("implement") || lower.Contains("code")) && (lower.Contains("```") || lower.Contains("c#"))) return QuestionType.Code;
        return QuestionType.Text;
    }

    private void SetAnswer(string val) => _practiceAnswers[_currentPracticeIndex] = val;

    private async Task NextQuestion()
    {
        if (_currentPracticeIndex < _currentModule!.PracticeQuestions.Count - 1)
        {
            _currentPracticeIndex++;
            try { await JS.InvokeVoidAsync("fluxionSound.play", "advance"); } catch {}
            try { await JS.InvokeVoidAsync("fluxionAnimations.slideIn", "practice-card", "right"); } catch {}
        }
    }

    private async Task SubmitPractice()
    {
        _isSubmitting = true;
        try
        {
            var payload = string.Join("\n\n---\n\n", _practiceAnswers);
            var req = new { LearnerId = _learnerId, NodeId = _currentModule!.NodeId, Response = payload, TimeSpentSeconds = (int)(DateTime.UtcNow - _sessionStartTime).TotalSeconds };
            var res = await Http.PostAsJsonAsync("api/curriculum/submit", req);
            _feedback = await res.Content.ReadFromJsonAsync<StudentFeedback>();
            
            if (_feedback?.NodeMastered == true)
            {
                _showMasteryOverlay = true;
                try { await JS.InvokeVoidAsync("fluxionSound.play", "mastered"); } catch {}
            }
            else
            {
                try { await JS.InvokeVoidAsync("fluxionSound.play", "wrong"); } catch {}
            }

            // Real Mastery update after answering
            _ = RefreshMasteryData();

            // Cognitive Load Recalculation (BUG 1)
            var wasCorrect = _feedback?.NodeMastered == true || _feedback?.MasteryScore >= 0.7;
            _recentAnswers.Add(new AnswerRecord 
            { 
                IsCorrect = wasCorrect,
                AnsweredAt = DateTime.UtcNow
            });
            _cognitiveLoad = CalculateCognitiveLoad();

            try {
                await JS.InvokeVoidAsync("fluxionBrainState.update", "brain-state-canvas", _cognitiveLoad);
            } catch { }

            try
            {
                await Http.PutAsJsonAsync($"api/curriculum/learners/{_learnerId}/cognitive-load", new { CognitiveLoadIndex = _cognitiveLoad });
            }
            catch { /* non-critical, don't block UI */ }
        }
        catch { _initError = "Submission failed."; }
        _isSubmitting = false;
    }

    private void RecalculateMastery()
    {
        try
        {
            if (_learner == null || _allNodes == null) return;
            
            _totalNodes = _allNodes.Count;
            _masteredCount = 0;
            
            foreach (var node in _allNodes)
            {
                var score = _learner.MasteryEntries.FirstOrDefault(m => m.NodeId == node.Id)?.MasteryScore ?? 0;
                if (score >= node.MasteryThreshold)
                {
                    _masteredCount++;
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Mastery calc error: {ex.Message}");
        }
    }

    private double CalculateCognitiveLoad()
    {
        try
        {
            if (_recentAnswers == null || _recentAnswers.Count == 0)
            {
                return Math.Max(_learner?.CognitiveLoadIndex ?? 0.3, 0.3);
            }
            
            // Safe TakeLast alternative
            var total = _recentAnswers.Count;
            var skip = Math.Max(0, total - 5);
            var recent = _recentAnswers.Skip(skip).ToList();
            
            if (recent.Count == 0) return 0.3;
            
            var correctCount = 0;
            foreach (var a in recent)
                if (a.IsCorrect) correctCount++;
            
            var accuracy = (double)correctCount / recent.Count;
            var load = 1.0 - (accuracy * 0.7) - 0.1;
            
            // Manual Clamp
            if (load < 0.15) load = 0.15;
            if (load > 0.95) load = 0.95;
            
            return load;
        }
        catch
        {
            return 0.3;
        }
    }

    private void StartSessionTimer()
    {
        _sessionStartTime = DateTime.UtcNow;
        _sessionTimerObj?.Dispose();
        _sessionTimerObj = new System.Threading.Timer(async _ =>
        {
            var elapsed = DateTime.UtcNow - _sessionStartTime;
            _sessionTimerDisplay = $"{(int)elapsed.TotalMinutes}:{elapsed.Seconds:D2}";
            await InvokeAsync(StateHasChanged);
        }, null, 0, 1000);
    }

    private async void RebindJS()
    {
        try 
        {
            await Task.Delay(100);
            await JS.InvokeVoidAsync("fluxionBrainState.draw", "brain-state-canvas", _cognitiveLoad);
            await JS.InvokeVoidAsync("fluxionAnimations.countUp", "stat-mastered", _masteredCount, 1000);
            await JS.InvokeVoidAsync("fluxionAnimations.countUp", "stat-streak", _streak, 1000);
        } catch {}
    }

    private double? GetNodeThreshold(Guid nodeId)
    {
        return _allNodes?
            .FirstOrDefault(n => n.Id == nodeId)
            ?.MasteryThreshold ?? 0.7;
    }

    private async Task RefreshMasteryData()
    {
        try
        {
            var learnerId = await LocalStorage.GetItemAsync<Guid>("learnerId");
            if (learnerId != Guid.Empty)
            {
                _learner = await Http.GetFromJsonAsync<LearnerProfile>($"api/curriculum/learners/{learnerId}");
                
                if (_learner != null && _allNodes != null)
                {
                    _masteredCount = _learner.MasteryEntries
                        .Count(m => m.MasteryScore >= (_allNodes.FirstOrDefault(n => n.Id == m.NodeId)?.MasteryThreshold ?? 0.7));
                }
                StateHasChanged();
                RebindJS(); // refresh DOM numbers
            }
        }
        catch { }
    }

    private string GetBrainStateLabel(double load) => load switch {
        var l when l < 0.3 => "Relaxed & Focused",
        var l when l < 0.6 => "Engaged",
        var l when l < 0.8 => "High Effort",
        _ => "Overloaded"
    };

