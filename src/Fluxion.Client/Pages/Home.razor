@page "/"
@using Fluxion.Core.Models
@using Microsoft.AspNetCore.SignalR.Client
@inject HttpClient Http
@inject NavigationManager Navigation
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@inject Blazored.LocalStorage.ILocalStorageService LocalStorage
@inject Fluxion.Client.Services.SoundService Sound
@inject Fluxion.Client.Services.ThemeService ThemeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Fluxion — AI-Powered Learning</PageTitle>

<AuthorizeView>
    <NotAuthorized>
        <!-- ── Unauthenticated Landing Page ── -->
        <section class="hero-section">
            <h1 class="hero-title">
                The future of <span class="text-gradient">adaptive</span> learning
            </h1>
            <p class="hero-subtitle">
                An AI-powered engine that morphs content in real-time based on your 
                cognitive profile. Personalized curriculum, reimagined.
            </p>
            <div class="hero-actions">
                <a href="/login" class="btn btn-outline" style="min-width:140px;">Sign In →</a>
                <a href="/register" class="btn btn-cyan" style="min-width:180px;">Get Started</a>
            </div>
        </section>

        <div class="bento-grid">
            <div class="bento-card">
                <div class="bento-icon">🧠</div>
                <h4>Adaptive Content</h4>
                <p class="text-dim">AI analyzes your cognitive load in real-time to morph lessons to your exact level and learning style.</p>
            </div>
            <div class="bento-card">
                <div class="bento-icon">📊</div>
                <h4>Mastery Tracking</h4>
                <p class="text-dim">Progress through a knowledge graph — unlock new concepts as you master fundamentals.</p>
            </div>
            <div class="bento-card">
                <div class="bento-icon">⚡</div>
                <h4>Active Recall</h4>
                <p class="text-dim">Practice exercises evaluated by AI with instant feedback and precision mastery scoring.</p>
            </div>
        </div>

        <div class="proof-section">
            <div class="text-dim" style="font-size:0.8rem; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; margin-bottom:1rem;">Built with purpose</div>
            <div class="proof-quote">
                "Learning should feel like a conversation, not a lecture."
            </div>
            <div class="text-dim">— The Fluxion Team</div>
        </div>

        <div class="cta-section">
            <h2 class="heading-xl mb-md">Ready to transform how you learn?</h2>
            <p class="text-dim mb-xl">Start your AI-orchestrated journey today. No credit card required.</p>
            <a href="/register" class="btn btn-cyan">Build Neural Path →</a>
        </div>
    </NotAuthorized>

    <Authorized>
        <!-- ── Authenticated Inner Dashboard Layout ── -->
        <div class="dashboard-inner-layout">
            
            <main class="center-panel">
                @if (_initError != null)
                {
                    <div class="glass-card module-card" style="padding:2.5rem; text-align:center;">
                        <div style="font-size:3rem; margin-bottom:1rem;">⚠️</div>
                        <h2 class="heading-lg mb-sm">Neural Link Failed</h2>
                        <p class="text-dim mb-xl">@_initError</p>
                        <button class="btn btn-cyan" @onclick="RetryInit">Retry Sync →</button>
                    </div>
                }
                else if (_isLoading)
                {
                    <div class="glass-card module-card module-loading-card">
                        <div class="spinner"></div>
                        <div class="module-loading-title">Initializing Neural Path...</div>
                        <p class="text-dim">@_loadingStatus</p>
                    </div>
                }
                else
                {
                    <div class="mb-xl">
                        <h2 class="heading-lg welcome-heading">Welcome back, @_username.</h2>
                    <p class="text-dim mb-xl">Your neural path is prepared and optimized.</p>

                    <div class="stat-card-row">
                        <div class="stat-badge-custom">
                            <div class="stat-icon">🧠</div>
                            <div class="stat-info">
                                <div class="stat-value"><span id="stat-load">@((_cognitiveLoad).ToString("P0"))</span></div>
                                <div class="stat-label">Cognitive Load</div>
                                <div class="stat-subtitle text-dim" id="stat-load-lbl">@GetBrainStateLabel(_cognitiveLoad)</div>
                            </div>
                        </div>
                        <div class="stat-badge-custom">
                            <div class="stat-icon">🎯</div>
                            <div class="stat-info">
                                <div class="stat-value"><span id="stat-mastered">@_masteredCount</span> / @_totalNodes</div>
                                <div class="stat-label">Mastered</div>
                            </div>
                        </div>
                        <div class="stat-badge-custom">
                            <div class="stat-icon">⚡</div>
                            <div class="stat-info">
                                <div class="stat-value"><span id="stat-streak">@_streak</span> days</div>
                                <div class="stat-label">Streak</div>
                            </div>
                        </div>
                    </div>
                </div>

                @if (_currentModule != null)
                {
                    if (!_inPracticeMode)
                    {
                        <!-- Step-by-Step Lesson Card -->
                        <div id="step-card" class="step-card">
                            <div class="step-progress-bar">
                                <div class="step-progress-header">
                                    <span class="step-counter">
                                        Step @(_currentStepIndex + 1) of @_steps.Count
                                    </span>
                                    <span class="step-time">
                                        ~@(_steps[_currentStepIndex].EstimatedMinutes) min read
                                    </span>
                                </div>
                                <div class="step-progress-track">
                                    <div class="step-progress-fill" 
                                         style="width: @((_currentStepIndex + 1) * 100 / _steps.Count)%">
                                    </div>
                                </div>
                            </div>

                            <h2 class="step-title">@_steps[_currentStepIndex].Title</h2>

                            <div class="step-content md-content">
                                @((MarkupString)SanitizeHtml(Markdig.Markdown.ToHtml(_steps[_currentStepIndex].Content)))
                            </div>

                            <div class="flex items-center justify-between mt-xl p-md" style="border-top: 1px solid var(--glass-border);">
                                <button class="btn btn-outline" 
                                        @onclick="PrevStep"
                                        disabled="@(_currentStepIndex == 0)">
                                    ← Previous
                                </button>
                                
                                <!-- Show "3 / 16" instead of 16 dots -->
                                <div style="font-size: 0.9rem; font-weight: 600; color: var(--text-muted); background: rgba(255,255,255,0.05); padding: 0.4rem 1rem; border-radius: 99px;">
                                    @(_currentStepIndex + 1) / @_steps.Count
                                </div>
                                
                                <button class="btn btn-cyan" 
                                        @onclick="NextStep">
                                    @(_currentStepIndex == _steps.Count - 1 
                                        ? "Practice →" 
                                        : "Next →")
                                </button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Practice Mode -->
                        <div id="practice-card" class="step-card">
                             <div class="flex items-center justify-between mb-lg">
                                <div class="heading-md flex items-center gap-sm"><span>⚡</span> Active Recall</div>
                                <span class="step-counter">Question @(_currentPracticeIndex + 1) of @_currentModule.PracticeQuestions.Count</span>
                            </div>

                            @if (_currentPracticeIndex < _currentModule.PracticeQuestions.Count)
                            {
                                var qText = _currentModule.PracticeQuestions[_currentPracticeIndex];
                                var cleanQ = CleanQuestion(qText);
                                var qType = DetectQuestionType(cleanQ);

                                <div class="step-content md-content mb-xl">
                                    @((MarkupString)SanitizeHtml(Markdig.Markdown.ToHtml(cleanQ)))
                                </div>

                                <div class="mb-xl">
                                    @if (qType == QuestionType.TrueFalse)
                                    {
                                        <div class="flex gap-md w-full">
                                            <button class="tf-btn true @(_practiceAnswers[_currentPracticeIndex] == "True" ? "active" : "")" 
                                                    @onclick="@(()=>SetAnswer("True"))">✓ True</button>
                                            <button class="tf-btn false @(_practiceAnswers[_currentPracticeIndex] == "False" ? "active" : "")" 
                                                    @onclick="@(()=>SetAnswer("False"))">✗ False</button>
                                        </div>
                                    }
                                    @if (qType == QuestionType.Code)
                                    {
                                        <textarea class="code-editor-area" 
                                                  @bind="_practiceAnswers[_currentPracticeIndex]" 
                                                  placeholder="// Write your code solution here..."></textarea>
                                    }
                                    @if (qType == QuestionType.Text)
                                    {
                                        <textarea class="input" style="min-height:140px;" 
                                                  @bind="_practiceAnswers[_currentPracticeIndex]" 
                                                  placeholder="Explain your reasoning..."></textarea>
                                    }
                                </div>

                                <div class="step-navigation">
                                    <button class="btn btn-outline" @onclick="@(() => _inPracticeMode = false)">← Back to Lesson</button>
                                    
                                    @if (_currentPracticeIndex < _currentModule.PracticeQuestions.Count - 1)
                                    {
                                        <button class="btn btn-cyan" @onclick="NextQuestion" 
                                                disabled="@string.IsNullOrWhiteSpace(_practiceAnswers[_currentPracticeIndex])">
                                            Next Question →
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-primary" @onclick="SubmitPractice" 
                                                disabled="@(_isSubmitting || string.IsNullOrWhiteSpace(_practiceAnswers[_currentPracticeIndex]))">
                                            @(_isSubmitting ? "Evaluating..." : "Complete Module →")
                                        </button>
                                    }
                                </div>
                            }
                        </div>
                    }
                }

                <!-- Feedback Display -->
                @if (_feedback != null)
                {
                    <div class="feedback-card @(_feedback.NodeMastered ? "success" : "warning")">
                        <div class="mastery-ring">
                            @((_feedback.MasteryScore * 100).ToString("F0"))%
                        </div>
                        <div style="flex:1;">
                            <h4 class="heading-md mb-sm">@(_feedback.NodeMastered ? "Mastery Achieved!" : "Needs Review")</h4>
                            <p class="text-dim mb-md">@_feedback.EvaluationDetails</p>
                            @if (_feedback.NodeMastered)
                            {
                                <button class="btn btn-cyan" @onclick="LoadNextModule">Next Module →</button>
                            }
                            else
                            {
                                <button class="btn btn-outline" @onclick="@(() => _feedback = null)">Retry Practice</button>
                            }
                        </div>
                    </div>
                }
                }
            </main>

            <!-- RIGHT SIDEBAR (Always Render) -->
            <aside class="right-sidebar">
                <!-- Brain State -->
                <div class="sidebar-card brain-state-card">
                    <div class="sidebar-card-title">
                        🧠 BRAIN STATE
                    </div>
                    <div class="brain-state-canvas-wrapper">
                        <canvas id="brain-state-canvas" 
                                width="140" 
                                height="120"
                                style="display:block; 
                                       width:140px;
                                       height:120px;
                                       margin:0 auto;
                                       opacity:0;
                                       transition:opacity 400ms ease;">
                        </canvas>
                    </div>
                    <div class="brain-state-label">
                        @GetBrainStateLabel(_cognitiveLoad)
                    </div>
                </div>

                <!-- AI Morphing Logic -->
                @if (_currentModule != null)
                {
                    <div class="sidebar-card">
                        <div class="sidebar-card-title @(_morphingExpanded ? "expanded" : "")" 
                             @onclick="() => _morphingExpanded = !_morphingExpanded"
                             style="cursor:pointer;">
                            🤖 Why this module? <span>▼</span>
                        </div>
                        @if (_morphingExpanded)
                        {
                            <p id="morphing-rationale" class="rationale-text">
                                @_currentModule.MorphingRationale
                            </p>
                        }
                    </div>
                }

                <!-- Session Stats -->
                <div class="sidebar-card">
                    <div class="sidebar-card-title">⏱ Session Stats</div>
                    <div class="stat-row">
                        <span>Time</span>
                        <span>@_sessionTimerDisplay</span>
                    </div>
                    <div class="stat-row">
                        <span>Format</span>
                        <span class="tag tag-pink">@(_currentModule?.SelectedFormat.ToString() ?? "—")</span>
                    </div>
                    <div class="stat-row">
                        <span>Difficulty</span>
                        <span>@(_currentModule?.AdjustedDifficulty ?? 0)/10</span>
                    </div>
                </div>

                <!-- Curriculum Mini-Map -->
                <div class="sidebar-card">
                    <div class="sidebar-card-title">📍 Curriculum</div>
                    @if (_allNodes != null)
                    {
                        <div class="node-pills">
                            @foreach (var node in _allNodes.OrderBy(n => n.DifficultyLevel).Take(8))
                            {
                                var score = _learner?.MasteryEntries.FirstOrDefault(m => m.NodeId == node.Id)?.MasteryScore ?? 0;
                                var state = score >= node.MasteryThreshold ? "mastered" : score > 0 ? "in-progress" : "locked";
                                <div class="node-pill @state">@node.Title</div>
                            }
                        </div>
                        <a href="/progress" class="view-all-link">View full map →</a>
                    }
                </div>
            </aside>
        </div>

        @if (_showMasteryOverlay)
        {
            <div class="mastery-overlay">
                @for(int i=0; i<30; i++)
                {
                    <div class="confetti" style="left:@(Random.Shared.Next(0,100))vw; animation-delay:@(Random.Shared.NextDouble())s; background: var(--accent-cyan)"></div>
                }
                <div class="mastery-banner">
                    <div style="font-size:4rem; margin-bottom:1rem;">🎉</div>
                    <h2 class="heading-xl text-gradient mb-sm">Goal Achieved!</h2>
                    <p class="text-dim">You have mastered <b>@_currentModule?.NodeTitle</b></p>
                    <button class="btn btn-cyan mt-xl" @onclick="CloseOverlay">Continue Path →</button>
                </div>
            </div>
        }
    </Authorized>
</AuthorizeView>

@code {
    private string _username = "";
    private Guid _learnerId;
    private LearnerProfile? _learner;
    private MorphedModule? _currentModule;
    private List<KnowledgeNode>? _allNodes;
    private string? _initError = null;
    private string _loadingStatus = "";
    private bool _isLoading = true;

    // Module Stepping
    private List<ModuleStep> _steps = new();
    private int _currentStepIndex = 0;
    private bool _inPracticeMode = false;
    private int _currentPracticeIndex = 0;
    private List<string> _practiceAnswers = new();

    // Stats & Session
    private string _sessionTimerDisplay = "0:00";
    private DateTime _sessionStartTime;
    private System.Threading.Timer? _sessionTimerObj;
    private bool _morphingExpanded = false;
    private int _masteredCount = 0;
    private int _totalNodes = 0;
    private int _streak = 1;

    private double _cognitiveLoad = 0.3;
    private class AnswerRecord
    {
        public bool IsCorrect { get; set; }
        public DateTime AnsweredAt { get; set; } = DateTime.UtcNow;
    }
    private List<AnswerRecord> _recentAnswers = new List<AnswerRecord>();

    private bool _isSubmitting = false;
    private StudentFeedback? _feedback;
    private bool _showMasteryOverlay = false;
    private bool _moduleLoaded = false;

    private HubConnection? _hubConnection;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    public class ModuleStep
    {
        public string Title { get; set; } = "";
        public string Content { get; set; } = "";
        public int EstimatedMinutes { get; set; } = 1;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Initial auth handled in OnAfterRenderAsync(firstRender) for WASM compat,
            // but we can prep the loading state here.
            _isLoading = true;
        }
        catch (Exception ex)
        {
            _initError = $"Critical boot error: {ex.Message}";
            _isLoading = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (firstRender && AuthState != null)
            {
                var state = await AuthState;
                if (state.User.Identity?.IsAuthenticated == true)
                {
                    _username = state.User.Identity.Name ?? "Learner";
                    await InitializeDashboard();
                }
                else
                {
                    _isLoading = false;
                    StateHasChanged();
                }
            }
            
            if (_learner != null && _moduleLoaded)
            {
                try
                {
                    await JS.InvokeVoidAsync("fluxionBrainState.draw", "brain-state-canvas", _cognitiveLoad);
                }
                catch (Exception ex)
                {
                    Console.WriteLine($"BrainState JS Error: {ex.Message}");
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Dashboard Render Crash Prevented: {ex.Message}");
        }
    }

    private async Task InitializeDashboard()
    {
        try
        {
            _isLoading = true;
            _initError = null;
            StateHasChanged();

            _learnerId = await LocalStorage.GetItemAsync<Guid>("learnerId");
            if (_learnerId == Guid.Empty)
            {
                _isLoading = false;
                _initError = "Neural identity not found. Please re-authenticate.";
                return;
            }

            // Load data
            _learner = await Http.GetFromJsonAsync<LearnerProfile>($"api/curriculum/learners/{_learnerId}");
            _allNodes = await Http.GetFromJsonAsync<List<KnowledgeNode>>("api/curriculum/graph/nodes");
            
            if (_learner != null)
            {
                RecalculateMastery();
                _cognitiveLoad = Math.Max(_learner.CognitiveLoadIndex, 0.3);
            }

            await InitializeStreak();
            await SetupSignalR();
            await LoadNextModule();
        }
        catch (HttpRequestException ex) when (ex.StatusCode == System.Net.HttpStatusCode.Unauthorized)
        {
            await LocalStorage.RemoveItemAsync("authToken");
            await LocalStorage.RemoveItemAsync("learnerId");
            Navigation.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            _initError = $"Dashboard calibration failed: {ex.Message}";
            _isLoading = false;
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private async Task RetryInit()
    {
        _initError = null;
        _isLoading = true;
        StateHasChanged();
        await InitializeDashboard();
    }

    // ═══ BUG 6 FIX: Streak initialization ═══
    private async Task InitializeStreak()
    {
        try
        {
            var lastDateStr = await LocalStorage.GetItemAsync<string>("fluxion_streak_date");
            var countStr = await LocalStorage.GetItemAsync<string>("fluxion_streak_count");
                
            var today = DateTime.UtcNow.Date;
            
            if (!string.IsNullOrEmpty(lastDateStr) && 
                DateTime.TryParse(lastDateStr, out var lastDate))
            {
                var daysDiff = (today - lastDate.Date).Days;
                _streak = int.TryParse(countStr, out var c) ? c : 0;
                
                if (daysDiff == 0)
                {
                    // Same day — keep streak
                }
                else if (daysDiff == 1)
                {
                    // Consecutive day — increment
                    _streak++;
                    await LocalStorage.SetItemAsync("fluxion_streak_date", today.ToString("O"));
                    await LocalStorage.SetItemAsync("fluxion_streak_count", _streak.ToString());
                }
                else
                {
                    // Streak broken
                    _streak = 1;
                    await LocalStorage.SetItemAsync("fluxion_streak_date", today.ToString("O"));
                    await LocalStorage.SetItemAsync("fluxion_streak_count", "1");
                }
            }
            else
            {
                // First visit
                _streak = 1;
                await LocalStorage.SetItemAsync("fluxion_streak_date", today.ToString("O"));
                await LocalStorage.SetItemAsync("fluxion_streak_count", "1");
            }
        }
        catch { _streak = 1; }
    }

    private async Task SetupSignalR()
    {
        var token = await LocalStorage.GetItemAsync<string>("authToken");
        var apiUrl = Configuration.GetValue<string>("ApiBaseUrl") ?? Navigation.BaseUri;
        
        _hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiUrl.TrimEnd('/')}/hubs/curriculum", options => {
                options.AccessTokenProvider = () => Task.FromResult(token);
            })
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<string>("OrchestrationProgress", async status => {
            _loadingStatus = status;
            await InvokeAsync(StateHasChanged);
        });

        _hubConnection.On<MorphedModule>("ModuleMorphed", async m => {
            SetupNewModule(m);
            await InvokeAsync(StateHasChanged);
        });

        await _hubConnection.StartAsync();
        await _hubConnection.SendAsync("JoinLearnerGroup", _learnerId.ToString());
    }

    private async Task LoadNextModule()
    {
        _isLoading = true;
        _initError = null;
        _feedback = null;
        _inPracticeMode = false;
        _moduleLoaded = false;
        StateHasChanged();

        try
        {
            var res = await Http.GetAsync($"api/curriculum/next/{_learnerId}");
            if (res.IsSuccessStatusCode)
            {
                var module = await res.Content.ReadFromJsonAsync<MorphedModule>();
                if (module != null) {
                    SetupNewModule(module);
                    _ = RefreshMasteryData(); // async update mastery stats
                }
            }
            else if (res.StatusCode == System.Net.HttpStatusCode.Unauthorized)
            {
                await LocalStorage.RemoveItemAsync("authToken");
                await LocalStorage.RemoveItemAsync("learnerId");
                Navigation.NavigateTo("/login");
                return;
            }
            else
            {
                _initError = "You've completed your current path topology!";
            }
        }
        catch { _initError = "Connection error."; }
        
        _isLoading = false;
        _moduleLoaded = true;
        StateHasChanged();
    }

    private void SetupNewModule(MorphedModule m)
    {
        _currentModule = m;
        ParseModuleIntoSteps(m.Content);
        _practiceAnswers = new List<string>(new string[m.PracticeQuestions.Count]);
        _currentPracticeIndex = 0;
        StartSessionTimer();
        RebindJS();
    }

    private void ParseModuleIntoSteps(string markdownContent)
    {
        try
        {
            _steps = new List<ModuleStep>();
            if (string.IsNullOrWhiteSpace(markdownContent)) return;

            // Step 1: Remove answer keys
            var lines = markdownContent.Split('\n').ToList();
            lines = lines.Where(l => !System.Text.RegularExpressions
                .Regex.IsMatch(l.Trim(), 
                    @"^[\*\-]?\s*[\*_]*Answer[\*_]*\s*[:.]",
                    System.Text.RegularExpressions.RegexOptions
                        .IgnoreCase))
                .ToList();
            var content = string.Join('\n', lines);

            // Step 2: Try splitting by H3 (###) first — more granular
            var h3Pattern = @"(?=^###\s)";
            var h3Sections = System.Text.RegularExpressions.Regex
                .Split(content, h3Pattern,
                    System.Text.RegularExpressions.RegexOptions.Multiline)
                .Where(s => !string.IsNullOrWhiteSpace(s))
                .ToList();

            // Step 3: If H3 gives us 3+ sections, use H3 splitting
            if (h3Sections.Count >= 3)
            {
                foreach (var section in h3Sections)
                {
                    var sLines = section.Split('\n');
                    var title = sLines[0].TrimStart('#').Trim();
                    var body = string.Join('\n', sLines.Skip(1)).Trim();
                    
                    // Skip "Sections:" header-only steps
                    if (title.Equals("Sections", 
                        StringComparison.OrdinalIgnoreCase)) continue;
                    if (string.IsNullOrWhiteSpace(body) && 
                        title.Length < 3) continue;
                    
                    // If body is too long (>600 chars), split further
                    // by numbered items or blank lines
                    if (body.Length > 600)
                    {
                        var subSteps = SplitLongSection(title, body);
                        _steps.AddRange(subSteps);
                    }
                    else
                    {
                        _steps.Add(CreateStep(title, body));
                    }
                }
            }
            else
            {
                // Fall back to H2 splitting
                var h2Pattern = @"(?=^##\s)";
                var h2Sections = System.Text.RegularExpressions.Regex
                    .Split(content, h2Pattern,
                        System.Text.RegularExpressions.RegexOptions
                            .Multiline)
                    .Where(s => !string.IsNullOrWhiteSpace(s))
                    .ToList();

                foreach (var section in h2Sections)
                {
                    var sLines = section.Split('\n');
                    var title = sLines[0].TrimStart('#').Trim();
                    var body = string.Join('\n', sLines.Skip(1)).Trim();
                    
                    if (string.IsNullOrWhiteSpace(body)) continue;
                    
                    if (body.Length > 600)
                    {
                        var subSteps = SplitLongSection(title, body);
                        _steps.AddRange(subSteps);
                    }
                    else
                    {
                        _steps.Add(CreateStep(title, body));
                    }
                }
            }

            // Step 4: Fallback — split by double newlines into chunks
            if (_steps.Count <= 1)
            {
                _steps = new List<ModuleStep>();
                var paragraphs = content
                    .Split(new[] {"\n\n", "\r\n\r\n"}, 
                        StringSplitOptions.RemoveEmptyEntries)
                    .Where(p => p.Trim().Length > 50)
                    .ToList();
                
                // Group every 2-3 paragraphs into one step
                for (int i = 0; i < paragraphs.Count; i += 2)
                {
                    var chunk = string.Join("\n\n", 
                        paragraphs.Skip(i).Take(2));
                    var firstLine = chunk.Split('\n')[0]
                        .TrimStart('#').Trim();
                    _steps.Add(CreateStep(
                        firstLine.Length > 3 ? firstLine : $"Part {i/2 + 1}", 
                        chunk));
                }
            }

            // Ensure at least 1 step
            if (_steps.Count == 0)
            {
                _steps.Add(CreateStep(
                    _currentModule!.NodeTitle, content));
            }

            // Bug 5 filtering
            _steps = _steps.Where(step => !IsMetadataStep(step)).ToList();

            // Safety fallback if everything was filtered
            if (_steps.Count == 0)
            {
                _steps.Add(CreateStep(_currentModule!.NodeTitle, content));
            }

            _currentStepIndex = 0;
            _inPracticeMode = false;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fallback Parse: {ex.Message}");
            _steps = new List<ModuleStep> { 
                new ModuleStep { 
                    Title = _currentModule?.NodeTitle ?? "Lesson", 
                    Content = markdownContent,
                    EstimatedMinutes = 3
                }
            };
        }
    }

    private bool IsMetadataStep(ModuleStep step)
    {
        try
        {
            if (step == null) return true;
            var content = (step.Content ?? "").Trim();
            var title = (step.Title ?? "").Trim().ToLower();
            
            if (content.Length < 30) return true;
            
            if (title.Contains("personalized learning module")) return true;
            if (title == "learning module") return true;
            if (title == "module overview") return true;
            
            var lines = content.Split('\n')
                .Where(l => l.Trim().Length > 0)
                .ToList();
            
            if (lines.Count <= 2)
            {
                var metaKeywords = new[] 
                { 
                    "topic:", "module:", "subject:", "unit:", 
                    "chapter:", "level:", "difficulty:", 
                    "format:", "objective:", "goal:" 
                };
                var allMeta = lines.All(l => 
                    metaKeywords.Any(k => 
                        l.Trim().ToLower().StartsWith(k)));
                if (allMeta) return true;
            }
            
            return false;
        }
        catch { return false; }
    }

    private List<ModuleStep> SplitLongSection(string parentTitle, string body)
    {
        var result = new List<ModuleStep>();
        parentTitle = parentTitle.Replace("Learning Module: ", "", StringComparison.OrdinalIgnoreCase)
                                 .Replace("Learning Module - ", "", StringComparison.OrdinalIgnoreCase);
        parentTitle = parentTitle.Length > 50 ? parentTitle.Substring(0, 47) + "..." : parentTitle;
        
        var paragraphs = body.Split(new[] { "\n\n", "\r\n\r\n" }, StringSplitOptions.RemoveEmptyEntries);
        var chunk = new System.Text.StringBuilder();
        var partNum = 1;

        foreach (var p in paragraphs)
        {
            var text = p.Trim();
            if (string.IsNullOrWhiteSpace(text)) continue;

            chunk.AppendLine(text);
            chunk.AppendLine();
            
            if (chunk.Length > 400)
            {
                result.Add(CreateStep($"{parentTitle} (Part {partNum++})", chunk.ToString().Trim()));
                chunk.Clear();
            }
        }
        if (chunk.Length > 0)
        {
            result.Add(CreateStep($"{parentTitle} (Part {partNum})", chunk.ToString().Trim()));
        }
        
        return result;
    }

    private ModuleStep CreateStep(string title, string content)
    {
        var wordCount = content.Split(
            new[]{' ','\n'}, 
            StringSplitOptions.RemoveEmptyEntries).Length;
        return new ModuleStep
        {
            Title = title,
            Content = content,
            EstimatedMinutes = Math.Max(1, wordCount / 200)
        };
    }

    private async Task NextStep()
    {
        if (_currentStepIndex < _steps.Count - 1)
        {
            _currentStepIndex++;
            try { await JS.InvokeVoidAsync("fluxionSound.play", "advance"); } catch {}
            try { await JS.InvokeVoidAsync("fluxionAnimations.slideIn", "step-card", "right"); } catch {}
        }
        else
        {
            _inPracticeMode = true;
            _currentPracticeIndex = 0;
            try { await JS.InvokeVoidAsync("fluxionSound.play", "advance"); } catch {}
        }
    }

    private async Task PrevStep()
    {
        if (_currentStepIndex > 0)
        {
            _currentStepIndex--;
            try { await JS.InvokeVoidAsync("fluxionSound.play", "advance"); } catch {}
            try { await JS.InvokeVoidAsync("fluxionAnimations.slideIn", "step-card", "left"); } catch {}
        }
